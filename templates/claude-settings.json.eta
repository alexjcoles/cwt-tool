{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "CWT_WORKTREE_NAME=<%= it.worktreeName %> bash $CLAUDE_PROJECT_DIR/.claude/hooks/cwt-session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/validate-plan.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/validate-deferral.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/validate-deferral.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/validate-commit-trailer.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Linear__save_issue",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/validate-issue.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "CWT_STATUS_DIR=/var/cwt/<%= it.worktreeName %> CWT_WORKTREE_NAME=<%= it.worktreeName %> node /cwt/channel/hook.js"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "LS",
      "TodoWrite",
      "mcp__cwt-channel__report_status",
      "mcp__cwt-channel__note"
    ]
  }
}
