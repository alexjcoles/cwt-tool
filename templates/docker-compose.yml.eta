# Generated by cwt for worktree: <%= it.worktreeName %>
# Compose project: <%= it.composeProject %>
# Port block: <%= it.portBase %>-<%= it.portBase + 99 %>
#   <%= it.portBase + 0 %>  Rails (dev server)
#   <%= it.portBase + 99 %>  Channel HTTP (M2)
name: "<%= it.composeProject %>"

services:
  <%= it.serviceName %>:
    build:
      context: <%= it.worktreePath %>
      dockerfile: <%= it.dockerfile %>
    image: <%= it.composeProject %>-app
    container_name: <%= it.composeProject %>-app
    working_dir: /workspaces/<%= it.worktreeName %>
    volumes:
      - <%= it.worktreePath %>:/workspaces/<%= it.worktreeName %>:cached
      # Mount source repo's .git at the same absolute path inside the container
      # so the worktree's .git pointer (which holds a host absolute path) resolves
      # in both places. Lets `git status/commit/log` work from inside the container.
      - <%= it.repoRoot %>/.git:<%= it.repoRoot %>/.git:cached
      - cwt-bundle-cache:/usr/local/bundle
      - cwt-cargo-registry:/root/.cargo/registry
      # Persist claude.ai login + sessions across cwt worktrees so /login is a
      # one-time thing. Volume ownership is fixed up by a postStartCommand
      # injected in the merged devcontainer config (Docker creates new named
      # volumes root-owned, but the container runs as vscode).
      - cwt-claude-config:/home/vscode/.claude
      - cwt-gh-config:/home/vscode/.config/gh
      # cwt channel: MCP server bundle + activity hook, mounted read-only.
      - <%= it.channelDist %>:/cwt/channel:ro
      # Worktree status dir: shared between container and host so cwt status,
      # cwt logs, and the future dashboard can read what each Claude reports.
      - <%= it.statusDir %>:/var/cwt/<%= it.worktreeName %>:cached
<% if (it.dataMount) { %>
      - <%= it.dataMount %>:/workspaces/<%= it.worktreeName %>/storage:cached
<% } %>
<% if (it.javaRef) { %>
      # Original Java PatentSafe codebase, read-only — used by cwt-java-explore
      # and the Java flow tracer subagent for plan-minor.
      - <%= it.javaRef %>:/workspaces/patentsafe:cached,ro
<% } %>
    environment:
      CWT_WORKTREE_NAME: <%= it.worktreeName %>
      CWT_PORT_BASE: "<%= it.portBase %>"
      # Project's database.yml drives the DB name; we only point it at
      # this worktree's postgres container.
      DB_HOST: postgres
      DB_USER: postgres
      DB_PASSWORD: postgres
      RAILS_ENV: development
      BINDING: 0.0.0.0
      CAPYBARA_SERVER_PORT: "45678"
      SELENIUM_HOST: selenium
      PATENTSAFE_DATA_ROOT: storage/repository
      PATENTSAFE_SERVER_ID: DEVC01
    ports:
      - "127.0.0.1:<%= it.portBase + 0 %>:3002"
      - "127.0.0.1:<%= it.portBase + 99 %>:8765"
    depends_on:
      postgres:
        condition: service_healthy
      selenium:
        condition: service_started
    networks:
      - app
    command: ["sleep", "infinity"]

  postgres:
    image: postgres:17-alpine
    container_name: <%= it.composeProject %>-pg
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: <%= it.dbName %>
    volumes:
      - postgres-data:/var/lib/postgresql/data
    networks:
      - app
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 10s

  selenium:
    image: selenium/standalone-chromium
    container_name: <%= it.composeProject %>-selenium
    restart: unless-stopped
    networks:
      - app

networks:
  app:
    driver: bridge

volumes:
  postgres-data:
  cwt-bundle-cache:
    name: cwt-bundle-cache
  cwt-cargo-registry:
    name: cwt-cargo-registry
  cwt-claude-config:
    name: cwt-claude-config
  cwt-gh-config:
    name: cwt-gh-config
